{
    "name": "winboat",
    "version": "0.9.0",
    "description": "Windows for Penguins",
    "type": "module",
    "main": "main/main.js",
    "engines": {
        "node": ">=23.6.0",
        "bun": ">=1.3.0"
    },
    "scripts": {
        "dev": "bun scripts/dev-server.ts",
        "build:app": "rm -rf build && vite build --config vite.config.ts && tsc -p src/main/tsconfig.json",
        "build:gs": "bash build-guest-server.sh",
        "build:linux-gs": "bash build-guest-server.sh && bun run build:app && electron-builder --linux",
        "type-check": "vue-tsc -p src/renderer/tsconfig.json --noEmit && tsc -p src/main/tsconfig.json --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "repository": "https://github.com/TibixDev/winboat",
    "author": {
        "name": "TibixDev",
        "url": "https://github.com/TibixDev",
        "email": "staff@winboat.app"
    },
    "devDependencies": {
        "@types/node-fetch": "^2.6.13",
        "@types/turndown": "^5.0.6",
        "@vitejs/plugin-vue": "^6.0.6",
        "autoprefixer": "^10.5.0",
        "chalk": "^5.6.2",
        "chokidar": "^5.0.0",
        "electron": "^40.9.2",
        "electron-builder": "^26.9.0",
        "postcss": "^8.5.12",
        "prettier": "^3.8.3",
        "tailwindcss": "^3.4.17",
        "typescript": "~5.9.3",
        "vite": "^7.3.2",
        "vue-tsc": "^3.2.7"
    },
    "dependencies": {
        "@electron/remote": "^2.1.3",
        "@iconify/vue": "^5.0.0",
        "@vueuse/core": "^14.2.1",
        "@vueuse/motion": "^3.0.3",
        "apexcharts": "^5.10.6",
        "argon2": "^0.44.0",
        "check-disk-space": "^3.4.0",
        "consola": "^3.4.2",
        "electron-store": "^11.0.2",
        "form-data": "^4.0.5",
        "marked": "^17.0.6",
        "nanoevents": "^9.1.0",
        "node-fetch": "2",
        "path-browserify": "^1.0.1",
        "turndown": "^7.2.4",
        "usb": "^2.17.0",
        "vue": "^3.5.33",
        "vue-router": "^5.0.6",
        "vue3-apexcharts": "^1.11.1",
        "xel": "^0.40.6",
        "yaml": "^2.8.3"
    }
}
